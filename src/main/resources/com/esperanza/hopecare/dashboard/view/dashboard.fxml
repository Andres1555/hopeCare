<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="15" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.esperanza.hopecare.dashboard.view.DashboardController">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20" />
    </padding>
    <Label fx:id="lblCitasHoy" styleClass="dashboard-card" />
    <Label fx:id="lblIngresosMes" styleClass="dashboard-card" />
    <Label text="Medicamentos con stock bajo:" />
    <ListView fx:id="listStockBajo" />
</VBox>
