<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox fx:id="root" spacing="15" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.esperanza.hopecare.citas.view.CitasController">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20" />
    </padding>

    <VBox fx:id="panelPacientes" spacing="5" VBox.vgrow="ALWAYS">
        <Label text="Pacientes disponibles:" style="-fx-font-weight: bold;" />
        <TableView fx:id="tvPacientes" prefHeight="180">
            <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
            <columns>
                <TableColumn text="ID" prefWidth="-1" />
                <TableColumn text="Nombre" prefWidth="-1" />
                <TableColumn text="Documento" prefWidth="-1" />
            </columns>
        </TableView>
    </VBox>

    <VBox fx:id="panelMedicos" spacing="5" VBox.vgrow="ALWAYS">
        <HBox spacing="10">
            <ComboBox fx:id="cbEspecialidad" prefWidth="220" promptText="Filtrar por especialidad" />
            <TextField fx:id="txtBuscarMedico" promptText="Buscar médico por nombre..." HBox.hgrow="ALWAYS" />
        </HBox>
        <Label text="Médicos disponibles:" style="-fx-font-weight: bold;" />
        <TableView fx:id="tvMedicos" prefHeight="180">
            <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
            <columns>
                <TableColumn text="ID" prefWidth="-1" />
                <TableColumn text="Nombre" prefWidth="-1" />
                <TableColumn text="Especialidad" prefWidth="-1" />
                <TableColumn text="Registro" prefWidth="-1" />
            </columns>
        </TableView>
    </VBox>

    <GridPane hgap="10" vgap="10">
        <Label text="Día disponible:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
        <ComboBox fx:id="cbDias" GridPane.columnIndex="1" GridPane.rowIndex="0" prefWidth="250" promptText="Seleccione un médico primero" />

        <Label text="Fecha:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
        <DatePicker fx:id="dpFecha" GridPane.columnIndex="1" GridPane.rowIndex="1" />

        <Button fx:id="btnBuscar" text="Buscar horarios" GridPane.columnIndex="0" GridPane.rowIndex="2" />

        <Label text="Horario disponible:" GridPane.columnIndex="0" GridPane.rowIndex="3" />
        <ComboBox fx:id="cbHorarios" GridPane.columnIndex="1" GridPane.rowIndex="3" prefWidth="250" />

        <Button fx:id="btnReservar" text="Reservar cita" GridPane.columnIndex="0" GridPane.rowIndex="4" GridPane.columnSpan="2" />
    </GridPane>
</VBox>
