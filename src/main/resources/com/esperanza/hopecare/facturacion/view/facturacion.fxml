<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>

<VBox spacing="15" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.esperanza.hopecare.facturacion.view.FacturacionController">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20" />
    </padding>
    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="Buscar paciente:" />
        <TextField fx:id="txtBuscarPaciente" prefWidth="300" promptText="Escriba nombre o apellido..." />
        <Button fx:id="btnGenerar" text="Generar Factura" />
    </HBox>
    <TableView fx:id="tablaPacientes" prefHeight="160">
        <columns>
            <TableColumn fx:id="colPacId" text="ID" prefWidth="50" />
            <TableColumn fx:id="colPacNombre" text="Nombre" prefWidth="150" />
            <TableColumn fx:id="colPacApellido" text="Apellido" prefWidth="150" />
            <TableColumn fx:id="colPacDocumento" text="Documento" prefWidth="130" />
            <TableColumn fx:id="colPacPendiente" text="Pendiente por facturar" prefWidth="150" />
        </columns>
    </TableView>
    <Label text="Facturas emitidas:" style="-fx-font-weight: bold;" />
    <TableView fx:id="tablaFacturas" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colId" text="ID" prefWidth="60" />
            <TableColumn fx:id="colPaciente" text="Paciente" prefWidth="200" />
            <TableColumn fx:id="colFecha" text="Fecha" prefWidth="160" />
            <TableColumn fx:id="colSubtotal" text="Subtotal" prefWidth="100" />
            <TableColumn fx:id="colImpuesto" text="Impuesto" prefWidth="100" />
            <TableColumn fx:id="colTotal" text="Total" prefWidth="100" />
            <TableColumn fx:id="colEstado" text="Estado" prefWidth="100" />
        </columns>
    </TableView>
</VBox>
