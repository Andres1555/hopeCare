<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>

<VBox spacing="15" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.esperanza.hopecare.facturacion.view.FacturacionController">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20" />
    </padding>
    <HBox spacing="10">
        <Label text="ID Paciente:" />
        <TextField fx:id="txtIdPaciente" />
        <Button fx:id="btnGenerar" text="Generar Factura" />
    </HBox>
    <TextArea fx:id="txtResultado" editable="false" prefHeight="300" />
</VBox>
